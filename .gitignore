# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environments ──────────────────────────────────────
myenv/
venv/
env/
.venv/

# ── Secrets — NEVER commit ────────────────────────────────────
.env
!.env.example

# ── Trained models (regenerate with: python -m src.models.train_all) ──
models/*.pkl
!models/.gitkeep

# ── Data cache & dataset (regenerate with: python -m src.data.build_dataset) ──
data/cache/*
!data/cache/.gitkeep
data/raw/dataset.json
data/raw/dataset_meta.json
!data/raw/.gitkeep

# ── Logs ──────────────────────────────────────────────────────
*.log
api_log.txt

# ── Frontend ──────────────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.env
frontend/.env.local

# ── IDE / OS ──────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
